# =============================================================================
# Realtime Earth — configuration
# 复制为 .env (start.py 会自动复制)。所有项都有合理默认值，通常无需改动。
# Copy to .env (start.py does this automatically). Defaults work out of the box.
# =============================================================================

# 服务端口 / HTTP port (后端+前端共用，single port serves both API and SPA)
REALTIME_EARTH_PORT=8000

# 日志级别 / Logging level
REALTIME_EARTH_LOG_LEVEL=INFO

# 启用/禁用各数据源 / Toggle data sources (true / false)
REALTIME_EARTH_ENABLE_SATELLITES=true
REALTIME_EARTH_ENABLE_LIGHTNING=true
REALTIME_EARTH_ENABLE_EARTHQUAKES=true
REALTIME_EARTH_ENABLE_WILDFIRES=true
REALTIME_EARTH_ENABLE_VOLCANOES=true
REALTIME_EARTH_ENABLE_SOLAR=true

# NASA FIRMS MAP_KEY (可选，optional). 申请: https://firms.modaps.eosdis.nasa.gov/api/
# 没有 key 也能用，只是速率受限 / Without a key, FIRMS still serves data but with stricter limits.
REALTIME_EARTH_FIRMS_MAP_KEY=

# CORS — 允许的来源 (JSON 数组格式，pydantic-settings 2.x 要求)
# CORS allowed origins (JSON array, required by pydantic-settings 2.x)
REALTIME_EARTH_CORS_ORIGINS=["http://localhost:8000","http://localhost:5173","http://localhost:8080"]
